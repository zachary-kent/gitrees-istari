      (forall (s : S) . R s -> R (enter s))
      -> (forall (s : S) (n : nat) . R s -> resolve s n = var_traverse #1 n : term)
      -> R s
      -> var_traverse #2 enter resolve s t = t : term


intersect (S : U i) . forall (enter : S -> S) (resolve : S -> nat -> term substT) (s : S) (n : nat) .
  traverse substT enter resolve s (var substT n) = resolve s n : term substT

{}

define /SubstType i/
/
  exists (term : U i) .
  { var_traverse : (nat -> term) & (intersect (S : U i) . (S -> S) -> (S -> nat -> term) -> S -> term -> term)
  |
    (
      intersect (S : U i) . forall (enter : S -> S) (resolve : S -> nat -> term) (s : S) (n : nat) .
        var_traverse #2 enter resolve s (var_traverse #1 n) = resolve s n : term
    )
    &
    (
      intersect (S S' : U i) . forall (R : S -> S' -> U i) (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) (s : S) (s' : S') (t : term) .
      (forall (s : S) (s' : S') . R s s' -> R (enter s) (enter' s'))
      -> (forall (s : S) (s' : S') (n : nat) . R s s' -> resolve s n = resolve' s' n : term)
      -> R s s'
      -> var_traverse #2 enter resolve s t = var_traverse #2 enter' resolve' s' t : term
    )
    &
    (
      intersect (S : U i) . forall (R : S -> U i) (enter : S -> S) (resolve : S -> nat -> term) (s : S) (t : term) .
      (forall (s : S) . R s -> R (enter s))
      -> (forall (s : S) (n : nat) . R s -> resolve s n = var_traverse #1 n : term)
      -> R s
      -> var_traverse #2 enter resolve s t = t : term
    )
    &
    (
      intersect (S S' : U i) . forall (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) (s : S) (s' : S') (t : term) .
      var_traverse #2 enter resolve s (var_traverse #2 enter' resolve' s' t)
        = var_traverse #2
          (fn (p : S & S') . (enter (p #1), enter' (p #2)))
          (fn (p : S & S') (n : nat) . var_traverse #2 enter resolve (p #1) (resolve' (p #2) n))
          (s, s') t : term
    )
  }
//
  forall (i : level) . U (1 + i)
/;
introOf /i/.
unfold /SubstType/.
typecheck.
qed();


lemma "traverse_var"
/
  intersect (i : level) . forall (substT : SubstType i) .
  intersect (S : U i) . forall (enter : S -> S) (resolve : S -> nat -> term substT) (s : S) (n : nat) .
      traverse substT enter resolve s (var substT n) = resolve s n : term substT
/;
intro /i [termT [[traverseT varT] Hsub]]/.
unfold /term at all, traverse, var/.
intro /S enter resolve s n/.
reduce /Hsub/.
unhide.
apply /Hsub/.
qed();

lemma "traverse_parametric"
/
  intersect (i : level) . forall (substT : SubstType i) .
  intersect (S S' : U i) . forall (R : S -> S' -> U i) (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term substT) (resolve' : S' -> nat -> term substT) (s : S) (s' : S') (t : term substT) .
  (forall (s : S) (s' : S') . R s s' -> R (enter s) (enter' s'))
  -> (forall (s : S) (s' : S') (n : nat) . R s s' -> resolve s n = resolve' s' n : term substT)
  -> R s s'
  -> traverse substT enter resolve s t = traverse substT enter' resolve' s' t : term substT
/;
intro /i [termT [[traverseT varT] Hsub]]/.
unfold /term at all, traverse at all/.
reduce /Hsub/.
intro /S S' R enter enter' resolve resolve' s s' t H1 H2 H3/.
unhide.
apply /Hsub/ >> auto.
qed();

lemma "traverse_id"
/
  intersect (i : level) . forall (substT : SubstType i) .
  intersect (S : U i) . forall (R : S -> U i) (enter : S -> S) (resolve : S -> nat -> term substT) (s : S) (t : term substT) .
    (forall (s : S) . R s -> R (enter s))
    -> (forall (s : S) (n : nat) . R s -> resolve s n = var substT n : term substT)
    -> R s
    -> traverse substT enter resolve s t = t : term substT
/;
intro /i [termT [[traverseT varT] Hsub]]/.
unfold /term at all, traverse, var/.
intro /S R enter resolve s t H1 H2 H3/.
reduce /Hsub/.
unhide.
apply /Hsub/ >> auto.
qed();

typechecker ();



typedef
/
  datatype
    U 0
  of
    ctx : type =
    | Empty : ctx
    | Extend : ctx -> ty -> ctx
/;


defineInd /Gamma/
/
  catenate : ctx -> ctx of
  | Empty . Gamma
  | Extend Delta tau . Extend (catenate Delta) tau
//
  ctx -> ctx -> ctx
/;

typedef
/
  datatype
    forall (tau : ty) .
    U 0
  of
    bound : ctx -> type =
    | Z : forall (Gamma : ctx) . bound (Extend Gamma tau)
    | S : forall (sigma : ty) (Gamma : ctx) . bound Gamma -> bound (Extend Gamma sigma)
/;

typedef
/
  datatype
    U 0
  of
    term : ctx -> ty -> type =
    | Var : forall (Gamma : ctx) (tau : ty) . bound tau Gamma -> term Gamma tau
    (* | Zero : forall (Gamma : ctx) . term Gamma Nat *)
    | Num : forall (Gamma : ctx) . nat -> term Gamma Nat
    | Lam : forall (Gamma : ctx) (sigma tau : ty) . term (Extend Gamma sigma) tau -> term Gamma (Arrow sigma tau)
    | App : forall (Gamma : ctx) (sigma tau : ty) . term Gamma (Arrow sigma tau) -> term Gamma sigma -> term Gamma tau
    | Fix : forall (Gamma : ctx) (sigma : ty) . term Gamma (Arrow sigma sigma) -> term Gamma sigma
    | Succ : forall (Gamma : ctx) . term Gamma Nat -> term Gamma Nat
    | Pred : forall (Gamma : ctx) . term Gamma Nat -> term Gamma Nat
    | Ifz : forall (Gamma : ctx) (sigma : ty) . term Gamma Nat -> term Gamma sigma -> term Gamma sigma
/;

define /Subst Gamma Delta/ 
/
  forall (sigma : ty) . bound sigma Gamma -> term Delta sigma
//
  ctx -> ctx -> U 0
/;

unfold /Subst/.
typecheck.
qed ();

