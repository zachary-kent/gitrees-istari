lemma "traverse_id"
/
  intersect (i : level) .
    forall (S : U i) (R : S -> U i) (enter : S -> S) (resolve : S -> nat -> term) (s : S) (t : term) .
      (forall (s : S) . R s -> R (enter s)) ->
        (forall (s : S) (n : nat) . R s -> resolve s n = Var n : term) ->
          R s ->
          `traverse S enter resolve t s = t : term
/;

intro /i S R enter resolve s t Hrelenter Hres/.
revert /s/.
induction /t/ >> auto.
{
  intro /M IH s Hrel/.
  auto.
}
{
  intro /M IHM N IHN s Hrel/.
  auto.
}
{
  intro /M IH s Hrel/.
  auto.
}
{
  intro /M IH s Hrel/.
  auto.
}
{
  intro /M IH s HRel/.
  auto.
}
{
  intro /M IHM N IHN P IHP s Hrel/.
  auto.
}
qed ();



