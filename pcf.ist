Subst : Ctx тЖТ Ctx тЖТ Set
  Subst ╬У ╬Ф = тИА {A} тЖТ ╬У тИЛ A тЖТ term ╬Ф A
  
  Rename : Ctx тЖТ Ctx тЖТ Set
  Rename ╬У ╬Ф = тИА {A} тЖТ ╬У тИЛ A тЖТ ╬Ф тИЛ A
  
  extend-var : Rename ╬У ╬Ф тЖТ Rename (╬У # A) (╬Ф # A)
  extend-var ╧Б Z      =  Z
  extend-var ╧Б (S x)  =  S (╧Б x)

  lift : Rename ╬У (╬У # A)
  lift Z = S Z
  lift (S x) = S (lift x)
  
  rename : Rename ╬У ╬Ф тЖТ term ╬У B тЖТ term ╬Ф B
  rename ╧Б (` x)         = ` (╧Б x)
  rename ╧Б yes           = yes
  rename ╧Б no            = no
  rename ╧Б triv          = triv
  rename ╧Б (pair MтВБ MтВВ)  = pair (rename ╧Б MтВБ) (rename ╧Б MтВВ)
  rename ╧Б (fst M)       = fst (rename ╧Б M)
  rename ╧Б (snd M)       = snd (rename ╧Б M)
  rename ╧Б (lam M)       = lam (rename (extend-var ╧Б) M)
  rename ╧Б (app M MтВБ)    = app (rename ╧Б M) (rename ╧Б MтВБ)
  rename ╧Б zero          = zero
  rename ╧Б (suc M)       = suc (rename ╧Б M)
  rename ╧Б (rec MтВА MтВБ M) = rec (rename ╧Б MтВА) (rename (extend-var ╧Б) MтВБ) (rename ╧Б M)
  
  weaken : Subst ╬У ╬Ф тЖТ Subst (╬У # A) (╬Ф # A)
  weaken ╬│ Z     = ` Z
  weaken ╬│ (S x) = rename S (╬│ x)
  
  subst : Subst ╬У ╬Ф тЖТ term ╬У A тЖТ term ╬Ф A
  subst ╬│ (` x)         = ╬│ x
  subst ╬│ yes           = yes
  subst ╬│ no            = no
  subst ╬│ triv          = triv
  subst ╬│ (pair MтВБ MтВВ)  = pair (subst ╬│ MтВБ) (subst ╬│ MтВВ)
  subst ╬│ (fst M)       = fst (subst ╬│ M)
  subst ╬│ (snd M)       = snd (subst ╬│ M)
  subst ╬│ (lam M)       = lam (subst (weaken ╬│) M)
  subst ╬│ (app M MтВБ)    = app (subst ╬│ M) (subst ╬│ MтВБ)
  subst ╬│ zero          = zero
  subst ╬│ (suc M)       = suc (subst ╬│ M)
  subst ╬│ (rec MтВА MтВБ M) = rec (subst ╬│ MтВА) (subst (weaken ╬│) MтВБ) (subst ╬│ M)
  
  extend : term ╬Ф A тЖТ Subst ╬У ╬Ф тЖТ Subst (╬У # A) ╬Ф
  extend M ╬│ Z     = M
  extend M ╬│ (S x) = ╬│ x
  
  _[_] : term (╬У # B) A тЖТ term ╬У B тЖТ term ╬У A
  N [ M ] = subst (extend M `_) N
  
  data _тЖж_ : term ┬╖ A тЖТ term ┬╖ A тЖТ Set where
    step-fst   : {M M' : term ┬╖ (prod AтВБ AтВВ)} тЖТ (M тЖж M') тЖТ (fst M тЖж fst M')
    step-fst-╬▓ : {MтВБ : term ┬╖ AтВБ} {MтВВ : term ┬╖ AтВВ} тЖТ (fst (pair MтВБ MтВВ) тЖж MтВБ)
    step-snd   : {M M' : term ┬╖ (prod AтВБ AтВВ)} тЖТ (M тЖж M') тЖТ (snd M тЖж snd M')
    step-snd-╬▓ : {MтВБ : term ┬╖ AтВБ} {MтВВ : term ┬╖ AтВВ} тЖТ (snd (pair MтВБ MтВВ) тЖж MтВВ)
    step-app   : {MтВБ MтВБ' : term ┬╖ (arr AтВБ AтВВ)} {MтВВ : term ┬╖ AтВБ} тЖТ (MтВБ тЖж MтВБ') тЖТ (app MтВБ MтВВ) тЖж (app MтВБ' MтВВ)
    step-app-╬▓ : {MтВВ : term (┬╖ # AтВБ) AтВВ} {MтВБ : term ┬╖ AтВБ} тЖТ (app (lam MтВВ) MтВБ) тЖж (MтВВ [ MтВБ ])
    step-rec   : тИА {MтВА : term ┬╖ A} {MтВБ M M'} тЖТ (M тЖж M') тЖТ (rec MтВА MтВБ M тЖж rec MтВА MтВБ M')
    step-rec-╬▓тВА : тИА {MтВА : term ┬╖ A} {MтВБ} тЖТ (rec MтВА MтВБ zero тЖж MтВА)
    step-rec-╬▓тВБ : тИА {MтВА : term ┬╖ A} {MтВБ M} тЖТ (rec MтВА MтВБ (suc M) тЖж (MтВБ [ rec MтВА MтВБ M ]))
  
  data _тЖж*_ : term ┬╖ A тЖТ term ┬╖ A тЖТ Set where
    тЖж*-refl : {M : term ┬╖ A} тЖТ M тЖж* M
    тЖж*-step : {M M' M'' : term ┬╖ A} тЖТ M тЖж M' тЖТ M' тЖж* M'' тЖТ M тЖж* M''
  
  тЖж*-trans : {M M' M'' : term ┬╖ A} тЖТ M тЖж* M' тЖТ M' тЖж* M'' тЖТ M тЖж* M''
  тЖж*-trans тЖж*-refl step = step
  тЖж*-trans (тЖж*-step stepтВБ stepтВВ) step = тЖж*-step stepтВБ (тЖж*-trans stepтВВ step)
  
  compatible : {p : term ┬╖ A тЖТ term ┬╖ B}
    тЖТ ({M M' : term ┬╖ A} тЖТ M тЖж M' тЖТ p M тЖж p M')
    тЖТ {M M' : term ┬╖ A} тЖТ M тЖж* M' тЖТ p M тЖж* p M'
  compatible lift тЖж*-refl       = тЖж*-refl
  compatible lift (тЖж*-step x s) = тЖж*-step (lift x) (compatible lift s)
 



typedef
/
  datatype
    U 0
  of
    ctx : type =
    | Empty : ctx
    | Extend : ctx -> ty -> ctx
/;


define /cons {a} h t/
/
  (h, next t)
//
  intersect i . forall (a : U i) .
    a -> ev (stream a) -> stream a
/;

inference.
introOf /i a h t/.
unfold /cons/.
unrollTypeUniv /stream with i/.
typecheck.
qed ();



define /fst {a} s/
/
  s #1
//
  intersect i . forall (a : U i) .
    stream a -> a
/;

inference.
unfold /fst/.
typecheck.
reintro /s/.
unrollTypeUniv /stream with i in s/.
typecheck.
qed ();



define /snd {a} s/
/
  laterf (s #2)
//
  intersect i . forall (a : U i) .
    stream a -> ev (stream a)
/;

inference.
unfold /snd/.
typecheck.
reintro /s/.
unrollTypeUniv /stream with i in s/.
typecheck.
qed ();



reductions
/
  fst _ (cons _ x _) --> x ;
  snd _ (cons _ _ s) --> later s ;

  unfolding fst snd cons later
/;



define /count/
/
  ffix (fn (cf : future (nat -> stream nat)) n . 
          let next c = cf
          in
            cons n (later (now (c (succ n)))))
//
  nat -> stream nat
/;

unfold /count/.
typecheck.
qed ();



val red =
makeReduction
/
  count n --> cons nat n (later (now (count (succ n)))) ;

  unfolding count
  unrolling ffix
/;

Database.setUnroll (parseConstant /count/) (Reduction.user red);



define /Foralls {a} P/
/
  ffix (fn Ff s .
          let next F = Ff
          in
            P (fst s)
            & (bindevt t = `snd a s
               in
                 F t))
//
  intersect i . forall (a : U i) .
    (a -> U i) -> stream a -> U i
/;

inference.
introOf /i a P/.
unfold /Foralls/.
fold /manual (`bindevt _ _) within _ _/.
typecheck.
reintro /F s/.
unfold /snd/.
reduce //.
unrollTypeUniv /stream with i in s/.
typecheck.
qed ();



reductions
/
  Foralls a P (cons _ h te) --> P h & future (bindevt t = te in Foralls a P t) ;

  unfolding Foralls
  unrolling ffix
/;



lemma "Foralls_implies"
/
  forall i (a : U i) (P Q : a -> U i) (s : stream a) .
    (forall x . P x -> Q x)
    -> Foralls P s
    -> Foralls Q s
/;

inference.
intro /i a P Q s Himpl/.
revert /s/.
apply /ffix/.
intro /[IH] s Hs/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [t]/.
fold /cons h t in Hs in concl/.
reduce /Hs concl/.
destruct /Hs/ /Hh [Ht]/.
split >> auto.
split.
witness /bindevt_map _# 5 __ Ht/.
auto.
qed ();



lemma "Foralls_combine"
/
  forall i (a : U i) (P Q : a -> U i) (s : stream a) .
    Foralls P s
    -> Foralls Q s
    -> Foralls (fn x . P x & Q x) s
/;

inference.
intro /i a P Q/.
apply /ffix/.
intro /[IH] s HP HQ/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [t]/.
fold /cons h t in HP in HQ in concl/.
reduce /HP HQ concl/.
destruct /HP/ /HPh [HPt]/.
destruct /HQ/ /HQh [HQt]/.
split >> auto.
split.
so /bindevt_and _# 5 HPt HQt/ /Ht/.
witness /bindevt_map _# 5 __ Ht/.
reduce //.
intro /s (HPs HQs)/.
apply /IH/ >> auto.
qed ();



lemma "count_lower_bound"
/
  forall n .
    Foralls (fn m . n <= m) (count n)
/;

inference.
intro /n/.
assert /forall n' . 
          n <= n'
          -> Foralls (fn m . n <= m) (count n')/ /Hprop/ >>> [inference, idtac].
1:{
  apply /Hprop/.
  reflexivity.
  }
apply /ffix/.
intro /[IH] n' Hleq/.
unroll /count/.
reduce /concl/.
split.
  {
  auto.
  }
split.
split.
apply /IH/.
omega.
qed ();



define /filters {a} p/
/
  ffix (fn filtf s .
          let next filt = filtf
          in
            if p (fst s) then
              now (cons 
                     (fst s) 
                     (bindev t = snd s
                      in
                        later (filt t)))
            else
              (bindev t = snd s
               in
                 later (filt t)))
//
  intersect i . forall (a : U i) . (a -> bool) -> stream a -> ev (stream a)
/;

inference.
unfold /filters/.
typecheck.
qed ();



reductions
/
  filters a p (cons _ h te) -->
    if p h then 
      now (cons a 
             h
             (later
                (bindev t = te
                 in
                   later (filters a p t))))
      else
        later
          (bindev t = te
           in
             later (filters a p t)) ;

  unfolding filters
  unrolling ffix
/;



lemma "Foralls_filters"
/
  forall i (a : U i) (p : a -> bool) (s : stream a) .
    bindevt s' = filters p s
    in
      Foralls (fn x . istrue (p x)) s'
/;

inference.
intro /i a p/.
apply /ffix/.
intro /[IH] s/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [t]/.
fold /cons h t/.
reduce //.
boolCase /p h/ /Hp/.
  {
  split >> auto.
  split.
  split.
  rewrite /-> bindevt_assoc/.
  reduce //.
  apply /bindevt_simple/.  
  reduce //.
  intro /s/.
  auto.
  }

  {
  split.
  rewrite /-> bindevt_assoc/.
  apply /bindevt_simple/.
  reduce //.
  intro /s/.
  split.
  apply /IH/.
  }
qed ();



lemma "Foralls_filters_preserve"
/
  forall i (a : U i) (p : a -> bool) (Q : a -> U i) (s : stream a) .
    Foralls Q s
    -> bindevt s' = filters p s
       in
         Foralls Q s'
/;

inference.
intro /i a p Q/.
apply /ffix/.
intro /[IH] s Hs/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [te]/.
fold /cons h te in Hs in concl/.
reduce /Hs concl/.
destruct /Hs/ /Hh [Hte]/.
boolCase /p h/ /Hp/.
  {
  split >> auto.
  split.
  split.
  rewrite /-> bindevt_assoc/.
  reduce //.
  witness /bindevt_map _# 5 __ Hte/.
  reduce //.
  auto.
  }

  {
  split.
  rewrite /-> bindevt_assoc/.
  reduce //.
  witness /bindevt_map _# 5 __ Hte/.
  reduce //.
  intro /s Hs/.
  split.
  apply /IH/ >> auto.
  }
qed ();



define /sieve {a} d/
/
  ffix (fn sief s .
          let next sie = sief
          in
            cons 
              (fst s)
              (bindev t = snd s in
               bindev t' = filters (d (fst s)) t
               in
                 later (now (sie t'))))
//
  intersect i . forall (a : U i) . (a -> a -> bool) -> stream a -> stream a
/;

inference.
unfold /sieve/.
typecheck.
qed ();



reductions
/
  sieve a d (cons _ h te) -->
    cons a
      h
      (later
         (bindev t = te in
          bindev t' = filters a (d h) t 
          in 
            later (now (sieve a d t')))) ;

  unfolding sieve
  unrolling ffix
/;



lemma "sieve_preserve"
/
  forall i (a : U i) (P : a -> U i) (d : a -> a -> bool) (s : stream a) .
    Foralls P s
    -> Foralls P (sieve d s)
/;

inference.
intro /i a P d/.
apply /ffix/.
intro /[IH] s Hs/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [t]/.
fold /cons h t in Hs in concl/.
reduce /Hs concl/.
destruct /Hs/ /Hh [Ht]/.
split >> auto.
split.
split.
rewrite /-> bindevt_assoc/.
reduce //.
witness /bindevt_map _# 5 __ Ht/.
reduce //.
intro /s Hs/.
rewrite /-> bindevt_assoc/.
reduce //.
so /Foralls_filters_preserve _ _ (d h) _ _ Hs/ /H/.
witness /bindevt_map _# 5 __ H/.
reduce //.
auto.
qed ();



