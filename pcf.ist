define /stream a/
/
  rec X . a & future (ev X)
//
  intersect i . U i -> U i
/;

inference.
unfold /stream/.
typecheck.
qed ();


define /later_app {a b} ff fx/
/
  let next f = ff in
  let next x = fx in
  next (f x)
//
  intersect (i : level) . forall (a b : U i) . future (a -> b) -> future a -> future b
/;

inference.
introOf /i a b ff fx/.
unfold /later_app/.
typecheck.
qed ();

lemma "later_app_hom"
/
  intersect (i : level) . forall (a b : U i) (f : a -> b) (x : a) . 
    `later_app a b (next f) (next x) = next (f x) : future b
/;

intro /i a b f x/.
unfold /later_app/.
reflexivity.
qed ();


typedef
/
  datatype
    intersect (i : level) .
    U i
  of
    ty : type =
    | Nat : ty
    | Arrow : ty -> ty -> ty
/;

typedef
/
  datatype
    intersect (i : level) .
    U i
  of
    term : type =
    | Var : nat -> term
    (* | Zero : forall (Gamma : ctx) . term Gamma Nat *)
    | Num : nat -> term
    | Lam : term -> term
    | App : term -> term -> term
    | Fix : term -> term
    | Succ : term -> term
    | Pred : term -> term
    | Ifz : term -> term -> term -> term
/;

typedef
/
  datatype
    intersect (i : level) .
    U i
  of
    has_type : list ty -> term -> ty -> type =
    | VarTyped : forall (Gamma : list ty) (idx : nat) (sigma : ty) . (nth Gamma idx = Some sigma : option ty) -> has_type Gamma (Var idx) sigma
    | NumTyped : forall (Gamma : list ty) (n : nat) . has_type Gamma (Num n) Nat
    | LamTyped : forall (Gamma : list ty) (sigma tau : ty) (M : term) . 
        has_type (sigma :: Gamma) M tau -> has_type Gamma (Lam M) (Arrow sigma tau)
    | AppTyped : forall (Gamma : list ty) (sigma tau : ty) (M N : term) .
        has_type Gamma M (Arrow sigma tau) ->
        has_type Gamma N sigma ->
          has_type Gamma (App M N) tau
    | FixTyped : forall (Gamma : list ty) (sigma : ty) (M : term) .
        has_type Gamma M (Arrow sigma sigma) ->
          has_type Gamma (Fix M) sigma
    | SuccTyped : forall (Gamma : list ty) (M : term) .
        has_type Gamma M Nat ->
          has_type Gamma (Succ M) Nat
    | PredTyped : forall (Gamma : list ty) (M : term) .
        has_type Gamma M Nat ->
          has_type Gamma (Pred M) Nat
    | IfzTyped : forall (Gamma : list ty) (M N P : term) (sigma : ty) .
        has_type Gamma M Nat ->
        has_type Gamma N sigma ->
        has_type Gamma P sigma ->
          has_type Gamma (Ifz M N P) sigma
/;

defineInd /S enter resolve/
/
  traverse' : term -> S -> term of
  | Var i . fn s . resolve s i
  | Num n . fn s . Num n
  | Lam M . fn s . Lam (traverse' M (enter s))
  | App M N . fn s . App (traverse' M s) (traverse' N s)
  | Fix M . fn s . Fix (traverse' M s)
  | Succ M . fn s . Succ (traverse' M s)
  | Pred M . fn s . Pred (traverse' M s)
  | Ifz M N P . fn s . Ifz (traverse' M s) (traverse' N s) (traverse' P s)
//
  intersect (i : level) . forall (S : U i) . (S -> S) -> (S -> nat -> term) -> term -> S -> term
/;

define /traverse S enter resolve s M/
/
  traverse' S enter resolve M s
//
  intersect (i : level) . forall (S : U i) . (S -> S) -> (S -> nat -> term) -> S -> term -> term
/;

unfold /traverse/.
typecheck.
qed ();

val red = makeReduction
/
  traverse S enter resolve s M --> traverse' S enter resolve M s ;

  unfolding traverse
/;

Database.setUnroll (parseConstant /traverse/) (Reduction.user red);

lemma "traverse_var"
/
  intersect (i : level) .
  forall (S : U i) (enter : S -> S) (resolve : S -> nat -> term) (s : S) (n : nat) .
    traverse S enter resolve s (Var n) = resolve s n : term
/;

intro /i S enter resolve s n/.
unfold /traverse/.
reduce //.
auto.
qed ();

lemma "traverse_parametric"
/
  intersect (i : level) . 
    forall 
      (S S' : U i) (R : S -> S' -> U i) 
      (enter : S -> S) (enter' : S' -> S') 
      (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) 
      (s : S) (s' : S') (t : term) .
        (forall (s : S) (s' : S') . R s s' -> R (enter s) (enter' s')) ->
        (forall (s : S) (s' : S') (n : nat) . R s s' -> resolve s n = resolve' s' n : term) ->
        R s s' ->
        traverse S enter resolve s t = traverse S' enter' resolve' s' t : term
/;

intro /i S S' R enter enter' resolve resolve' s s' M Hrelenter Hagree/.
revert /s s'/.
unfold /traverse at all/.
induction /M/ >> auto.
{
  intro /n s s' Hrel/.
  auto.
}
{
  intro /n s s' Hrel/.
  auto.
}
{
  intro /M IH s s' Heq/.
  auto.
}
(* {
  intro /M IHM N IHN  s s' HRel/.
  compat >> auto.
} *)
{
  intro /M IH s s' Hrel/.
  auto.
}
{
  intro /M IH s s' Hrel/.
  auto.
}
{
  intro /M IHM N IHN P IHP s s' HRel/.
  auto.
}
qed ();

lemma "traverse_compose"
/
  intersect (i : level) .
    forall (S S' : U i) (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) (s : S) (s' : S') (M : term) .
      traverse S enter resolve s (traverse S' enter' resolve' s' M)
        = traverse (S & S')
            (fn (p : S & S') . (enter (p #1), enter' (p #2)))
            (fn (p : S & S') (n : nat) . traverse S enter resolve (p #1) (resolve' (p #2) n))
            (s, s') M : term
/;

intro /i S S' enter enter' resolve resolve' s s' M/.
revert /s s'/.
unfold /traverse at all/.
induction /M/ >> auto.
{
  intro /M IHM N IHN s s'/.
  auto.
}
{
  intro /M IHM N IHN P IHP s s'/.
  auto.
}
qed ();


   intersect (S S' : U i) . forall (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) (s : S) (s' : S') (t : term) .
      var_traverse #2 enter resolve s (var_traverse #2 enter' resolve' s' t)
        = var_traverse #2
          (fn (p : S & S') . (enter (p #1), enter' (p #2)))
          (fn (p : S & S') (n : nat) . var_traverse #2 enter resolve (p #1) (resolve' (p #2) n))
          (s, s') t : term *)
/

